const admin = require('firebase-admin');

// 1. IMPORTANTE: El nombre debe ser idéntico al archivo que tienes en la carpeta
// Si tu archivo se llama 'serviceAccountKey.json', cámbialo aquí abajo:
const serviceAccount = require("./key.json");

admin.initializeApp({
  credential: admin.credential.cert(serviceAccount)
});

const db = admin.firestore();

// Exportamos la base de datos para usarla en index.js
module.exports = db;